{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@views": ["./src/views"],
      "@views/*": ["./src/views/*"],
      "@imgs": ["./src/assets/images"],
      "@imgs/*": ["./src/assets/images/*"],
      "@icons": ["./src/assets/images/svg"],
      "@icons/*": ["./src/assets/images/svg/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@stores": ["./src/store"],
      "@stores/*": ["./src/store/*"],
      "@styles": ["./src/styles"],
      "@plugins/*": ["./src/plugins/*"],
      "@styles/*": ["./src/styles/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "useDefineForClassFields": true,
    "allowJs": true,
    "types": ["node", "vite/client", "element-plus/global"]
  },
  "include": ["src/types/**/*.d.ts", "src/**/*.ts", "src/**/*.vue", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "**/*.js"]
}
