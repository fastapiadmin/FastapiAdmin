{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@views/*": ["src/views/*"],
      "@imgs/*": ["src/assets/images/*"],
      "@icons/*": ["src/assets/icons/*"],
      "@utils/*": ["src/utils/*"],
      "@stores/*": ["src/store/*"],
      "@plugins/*": ["src/plugins/*"],
      "@styles/*": ["src/assets/styles/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "useDefineForClassFields": true,
    "allowJs": true,
    "types": ["node", "vite/client", "element-plus/global"]
  },
  "include": ["src/types/**/*.d.ts", "src/**/*.ts", "src/**/*.vue", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "**/*.js", "src/views/widgets/examples/**"]
}
